<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!-- Full regression suite: all UI tests plus the Cucumber BDD layer. -->
<!-- Runs sequentially for stability in CI. The framework is parallel-safe -->
<!-- (ThreadLocal driver); set parallel="classes" thread-count="N" to scale. -->
<suite name="SauceDemo Regression" verbose="1">

    <listeners>
        <listener class-name="com.saucedemo.listeners.TestListener"/>
    </listeners>

    <test name="UI Tests">
        <classes>
            <class name="com.saucedemo.tests.LoginTest"/>
            <class name="com.saucedemo.tests.InventoryTest"/>
            <class name="com.saucedemo.tests.CartTest"/>
            <class name="com.saucedemo.tests.CheckoutTest"/>
            <class name="com.saucedemo.tests.NavigationTest"/>
            <class name="com.saucedemo.tests.NegativeAccessTest"/>
        </classes>
    </test>

    <test name="BDD Tests">
        <classes>
            <class name="com.saucedemo.bdd.runner.CucumberRunnerTest"/>
        </classes>
    </test>
</suite>
